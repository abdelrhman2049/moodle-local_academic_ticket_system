<style>
    /* 1. Animated Background & General Styles */
    body {
        font-family: 'Cairo', sans-serif;
        background-color: #f0f2f5;
        overflow-x: hidden;
    }

    /* Mesh Gradient Animation */
    .animated-bg {
        position: fixed;
        top: 0; left: 0; width: 100vw; height: 100vh;
        z-index: -1;
        background: radial-gradient(at 0% 0%, hsla(253,16%,7%,1) 0, transparent 50%),
        radial-gradient(at 50% 0%, hsla(225,39%,30%,1) 0, transparent 50%),
        radial-gradient(at 100% 0%, hsla(339,49%,30%,1) 0, transparent 50%);
        background-size: 200% 200%;
        animation: gradientBG 15s ease infinite;
    }

    /* Ambient Blobs */
    .blob {
        position: absolute;
        filter: blur(80px);
        z-index: -1;
        opacity: 0.6;
        animation: float 10s infinite ease-in-out;
    }
    .blob-1 { top: 10%; left: 10%; width: 300px; height: 300px; background: #4f46e5; animation-delay: 0s; }
    .blob-2 { bottom: 20%; right: 10%; width: 350px; height: 350px; background: #ec4899; animation-delay: 2s; }
    .blob-3 { top: 40%; left: 40%; width: 250px; height: 250px; background: #06b6d4; animation-delay: 4s; }

    @keyframes gradientBG {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    @keyframes float {
        0% { transform: translate(0px, 0px) scale(1); }
        33% { transform: translate(30px, -50px) scale(1.1); }
        66% { transform: translate(-20px, 20px) scale(0.9); }
        100% { transform: translate(0px, 0px) scale(1); }
    }

    /* 2. Glassmorphism Utilities */
    .glass-panel {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.15);
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.65);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .glass-card:hover {
        background: rgba(255, 255, 255, 0.85);
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1);
        border-color: rgba(255, 255, 255, 0.9);
    }

    /* 3. Buttons & Inputs */
    .search-input {
        background: rgba(255, 255, 255, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(4px);
        transition: all 0.3s ease;
    }
    .search-input:focus {
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2);
        outline: none;
    }

    .btn-action {
        position: relative;
        overflow: hidden;
        z-index: 1;
        border: none;
        background-size: 200% auto;
        transition: 0.5s;
    }
    .btn-action:hover {
        background-position: right center;
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }

    /* Table Styling */
    .custom-table th {
        background: rgba(243, 244, 246, 0.8);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 0.75rem;
        color: #4b5563;
    }
    .custom-table tr {
        transition: all 0.2s ease;
        border-bottom: 1px solid rgba(0,0,0,0.03);
    }
    .custom-table tr:hover {
        background-color: rgba(255, 255, 255, 0.6);
        transform: scale(1.005);
    }
    .custom-table td {
        vertical-align: middle;
    }

    /* Status Badges */
    .badge-pill {
        padding: 0.35em 0.8em;
        border-radius: 50rem;
        font-weight: 700;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }
</style>


<style>
    [lang="ar"] .container { direction: rtl; }
    [lang="ar"] .text-right { text-align: right; }
    [lang="ar"]  .text-left { text-align: left; }
    [lang="ar"]   .fa-arrow-left { transform: rotate(0deg); }
    /* Fix search icon position in RTL */
    [lang="ar"]  .group .fa-search { left: auto; right: 1rem; }
    [lang="ar"]  .search-input { padding-left: 1rem; padding-right: 2.5rem; }

</style>

<script>
    function filterTickets() {
        var input, filter, table, tr, tdTitle, tdId, i, txtValueTitle, txtValueId;
        input = document.getElementById("ticketSearch");
        filter = input.value.toUpperCase();
        table = document.getElementById("ticketsTable");
        tr = table.getElementsByTagName("tr");

        for (i = 0; i < tr.length; i++) {
            // Column 0 is ID (hidden span usually, or displayed), Column 1 is Title
            tdId = tr[i].getElementsByTagName("td")[0];
            tdTitle = tr[i].getElementsByTagName("td")[1];

            if (tdId || tdTitle) {
                txtValueId = tdId.textContent || tdId.innerText;
                txtValueTitle = tdTitle.textContent || tdTitle.innerText;

                if (txtValueId.toUpperCase().indexOf(filter) > -1 || txtValueTitle.toUpperCase().indexOf(filter) > -1) {
                    tr[i].style.display = "";
                } else {
                    tr[i].style.display = "none";
                }
            }
        }
    }
</script>

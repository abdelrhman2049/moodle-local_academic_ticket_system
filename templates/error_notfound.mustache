<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

<style>
    body { font-family: 'Cairo', sans-serif; background-color: #f3f4f6; }
    .glass-error {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
    }
    .blob-err { position: absolute; filter: blur(60px); z-index: -1; opacity: 0.5; }
    .blob-e1 { top: 20%; left: 20%; width: 200px; height: 200px; background: #6366f1; }
    .blob-e2 { bottom: 20%; right: 20%; width: 250px; height: 250px; background: #a855f7; }
</style>

<div class="fixed inset-0 z-[-1] overflow-hidden">
    <div class="blob-err blob-e1 rounded-full"></div>
    <div class="blob-err blob-e2 rounded-full"></div>
</div>

<div class="min-h-[70vh] flex flex-col items-center justify-center p-4">
    <div class="glass-error p-10 rounded-3xl text-center max-w-lg w-full transform transition-all hover:scale-[1.01]">
        <div class="w-24 h-24 bg-indigo-50 rounded-full flex items-center justify-center mx-auto mb-6 shadow-sm">
            <i class="fas fa-search text-4xl text-indigo-500"></i>
        </div>
        <h2 class="text-3xl font-extrabold text-gray-800 mb-2">Ticket Not Found</h2>
        <p class="text-gray-500 mb-8 text-lg font-medium leading-relaxed">
            We couldn't find a ticket with ID <strong>#{{ticketid}}</strong>.<br>
            It may have been deleted or never existed.
        </p>
        <a href="{{home_url}}" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-xl font-bold text-lg hover:shadow-xl hover:-translate-y-1 transition-all w-full text-decoration-none">
            <i class="fas fa-arrow-left"></i> Return to List
        </a>
    </div>
</div>